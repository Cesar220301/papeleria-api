generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Producto {
  id           Int           @id @default(autoincrement())
  nombre       String
  precio       Decimal       @db.Decimal(10, 2)
  stock        Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ventaDetalles VentaDetalle[]
}

model Venta {
  id         Int           @id @default(autoincrement())
  subtotal   Decimal       @db.Decimal(10, 2)
  iva        Decimal       @db.Decimal(10, 2)
  total      Decimal       @db.Decimal(10, 2)
  fecha      DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  detalles   VentaDetalle[]
}

model VentaDetalle {
  id           Int      @id @default(autoincrement())
  ventaId      Int
  productoId   Int
  cantidad     Int
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal     Decimal  @db.Decimal(10, 2)
  iva          Decimal  @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([ventaId])
  @@index([productoId])
  @@unique([ventaId, productoId])
}
